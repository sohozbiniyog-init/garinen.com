node_modules
.vscode
.next
.github
.env
.env.local
# Ignore all files in the "node_modules" directory
node_modules/
# Ignore all files in the "dist" directory
dist/
# Ignore all files in the "build" directory
build/
# Ignore all files in the "coverage" directory
coverage/
# Ignore all files in the "out" directory
out/
# Ignore all files in the "public" directory except for "favicon.ico"
scripts/
# Track source code files (allow .tsx, .ts, .json in key directories)
!lib/**/*.ts
!lib/**/*.tsx
!components/**/*.ts
!components/**/*.tsx
!app/**/*.ts
!app/**/*.tsx
!pages/**/*.ts
!pages/**/*.tsx
# add all the sql,md,log,txt files(except readme.md, ARCHITECTURE guide, and setup guides) to ignore
*.sql
*.md
!README.md
*.log
*.txt
*.html



