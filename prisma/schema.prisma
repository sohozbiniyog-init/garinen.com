generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  VENDOR
  ADMIN
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  PURCHASED
  EMI_APPLIED
  EMI_PROCESSING
  EMI_APPROVED
}

enum CustomOrderStatus {
  PENDING
  UNDER_REVIEW
  QUOTED
  PURCHASED
  CANCELLED
}

enum OfferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OfferSource {
  VENDOR
  ADMIN
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AdminTier {
  SUPER_ADMIN
  VENDOR_ADMIN
  BASIC_ADMIN
}

enum VendorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProfessionType {
  DOCTOR
  ENGINEER
  BUSINESSMAN
  EMPLOYEE_GOVT
  EMPLOYEE_PVT
  TEACHER
  SELF_EMPLOYED
  ACTORS_INFLUENCER
  GAMERS_STREAMERS
  STUDENT
  OTHER
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  phone      String?  @unique
  name       String
  role       Role     @default(BUYER)
  avatarUrl  String?
  profession ProfessionType?
  
  // Admin fields
  adminTier  AdminTier?
  
  // Vendor fields
  vendorApprovalStatus  VendorApprovalStatus?
  vendorInfo            Json?  // Stores: shopName, description, category, etc.
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownedShop  Shop?
  bookings   Booking[]
  customOrders CustomOrder[]
  offers     Offer[]
  loanApplications LoanApplication[]
  audits     AuditLog[]
}

model Shop {
  id         String   @id @default(cuid())
  name       String
  ownerId    String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  listings   Listing[]
}

model Listing {
  id         String        @id @default(cuid())
  shopId     String
  title      String
  brand      String
  model      String
  year       Int
  price      Decimal       @db.Decimal(12, 2)
  mileage    Int?
  location   String
  imageUrls  Json?
  videoUrls  Json?
  status     ListingStatus @default(PENDING)
  adminNotes String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  shop       Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  reviews    Review[]

  @@index([shopId, status, createdAt])
  @@index([brand, model, status])
  @@index([location, status])
}

model Booking {
  id                String        @id @default(cuid())
  userId            String
  listingId         String
  status            BookingStatus @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  depositAmount     Decimal?      @db.Decimal(12, 2)
  currency          String        @default("BDT")
  paymentProvider   String?
  paymentIntentId   String?       @unique
  paymentReference  String?
  idempotencyKey    String?       @unique
  paidAt            DateTime?
  emiDetails        Json?
  address           String?
  profession        ProfessionType?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing           Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([listingId, status])
  @@index([paymentStatus, createdAt])
}

model CustomOrder {
  id        String             @id @default(cuid())
  userId    String
  brand     String
  model     String
  yearFrom  Int?
  yearTo    Int?
  budget    String?
  color     String?
  features  String?
  notes     String?
  status    CustomOrderStatus  @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([brand, status])
}

model Review {
  id           String   @id @default(cuid())
  listingId    String
  listingTitle String
  author       String
  location     String
  rating       Int
  content      String
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, featured, createdAt])
}

model Offer {
  id            String       @id @default(cuid())
  vendorId      String
  vendorName    String
  sourceRole    OfferSource  @default(VENDOR)
  title         String
  subtitle      String?
  description   String
  discountLabel String
  ctaLabel      String       @default("View Offer")
  ctaHref       String
  imageUrl      String?
  status        OfferStatus  @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  vendor       User         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, status, createdAt])
  @@index([status, sourceRole, createdAt])
}

model AuditLog {
  id          String       @id @default(cuid())
  actorUserId String?
  action      AuditAction
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime     @default(now())

  actor       User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

enum LoanStatus {
  DRAFT
  FOLLOW_UP_REQUIRED
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
}

model LoanApplication {
  id          String     @id @default(cuid())
  userId      String?
  name        String
  email       String
  phone       String?
  amount      Decimal?   @db.Decimal(12, 2)
  application Json
  documents   Json?
  status      LoanStatus @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
}

model AdminAccount {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  passwordHash  String
  tier          AdminTier
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tier])
  @@index([createdBy])
  @@index([email])
}
