{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",

  "model": "openai/gpt-4o-mini",
  "small_model": "openai/gpt-4o-mini",

  "lsp": false,
  "formatter": false,

  "logLevel": "ERROR",

  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },

  "compaction": {
    "auto": true,
    "tail_turns": 8
  },

  "agent": {
    "plan": {
      "description": "First-principles planner for every non-trivial task.",
      "mode": "primary",
      "model": "openai/gpt-4o-mini",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "bash": "allow",
        "edit": "deny",
        "write": "deny"
      }
    },
    "general": {
      "description": "General-purpose agent for research and multi-step tasks.",
      "mode": "subagent",
      "model": "openai/gpt-4o-mini",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "edit": "allow"
      }
    },
    "explore": {
      "description": "Fast codebase exploration agent.",
      "mode": "subagent",
      "model": "openai/gpt-4o-mini",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "task": "allow"
      }
    }
  }
}
